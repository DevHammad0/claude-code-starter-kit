# ============================================================
# Starter Kit .gitignore — copy and extend for your project
# ============================================================

# ---- Environment & Secrets (NEVER commit these) ------------
.env
.env.local
.env.development
.env.production
.env.*.local
*.env

# Private keys & certificates
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
secrets/
.secrets/

# ---- Frontend (Next.js / pnpm) -----------------------------
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.vercel/
frontend/coverage/
frontend/playwright-report/
frontend/test-results/
pnpm-debug.log*

# ---- Backend (Python / uv) ---------------------------------
backend/__pycache__/
backend/**/__pycache__/
backend/.venv/
backend/venv/
backend/.pytest_cache/
backend/htmlcov/
backend/coverage.xml
backend/.coverage
**/*.pyc
**/*.pyo

# ---- Auth Service (Node.js) --------------------------------
auth/node_modules/
auth/dist/

# ---- Docker ------------------------------------------------
*.log
docker-compose.override.yml

# ---- Supabase ----------------------------------------------
.supabase/

# ---- IDE & OS ----------------------------------------------
.vscode/
.idea/
.DS_Store
Thumbs.db
desktop.ini
*.sw?

# ---- Misc --------------------------------------------------
*.tsbuildinfo
.turbo/
tmp/
temp/
